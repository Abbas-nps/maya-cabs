# Supabase Migration — Config
# Copy this file to .env.migration and fill in the real values.
# NEVER commit .env.migration — it contains service-role keys.

# ── Free project ────────────────────────────────────────────────────────────
# Find in: Free project → Settings → API → Project URL
FREE_SUPABASE_URL=https://REPLACE_FREE_REF.supabase.co

# Use the service_role key (NOT the anon key) so RLS is bypassed during export.
# Find in: Free project → Settings → API → service_role (secret)
FREE_SUPABASE_KEY=REPLACE_FREE_SERVICE_ROLE_KEY

# ── Pro project ─────────────────────────────────────────────────────────────
# Find in: Pro project → Settings → API → Project URL
PRO_SUPABASE_URL=https://REPLACE_PRO_REF.supabase.co

# Use the service_role key for the Pro project too.
PRO_SUPABASE_KEY=REPLACE_PRO_SERVICE_ROLE_KEY

# ── Optional tuning ─────────────────────────────────────────────────────────

# Restrict migration to specific tables (comma-separated). Leave blank for all.
# ONLY_TABLES=bookings,drivers,customers

# Rows per upsert batch (default 500).
# BATCH_SIZE=500
